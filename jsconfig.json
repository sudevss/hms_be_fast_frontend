{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react",
    "paths": {
      // "*": ["src/*", "node_modules/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@contexts/*": ["src/contexts/*"],
      "@data/*": ["src/data/*"],
      "@features/*": ["src/features/*"],
      "@pages/*": ["src/pages/*"],
      "@utils/*": ["src/utils/*"],
      "@hooks/*": ["src/hooks/*"],
      "@/*": ["src/*"]
    }
  }
}
